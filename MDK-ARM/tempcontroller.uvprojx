<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<Project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="project_projx.xsd">
  <SchemaVersion>2.1</SchemaVersion>
  <Header>### uVision Project, (C) Keil Software</Header>
  <Targets>
    <Target>
      <TargetName>tempcontroller</TargetName>
      <ToolsetNumber>0x4</ToolsetNumber>
      <ToolsetName>ARM-ADS</ToolsetName>
      <pCCUsed>6110000::V6.11::ARMCLANG</pCCUsed>
      <uAC6>1</uAC6>
      <TargetOption>
        <TargetCommonOption>
          <Device>STM32F103ZE</Device>
          <Vendor>STMicroelectronics</Vendor>
          <PackID>Keil.STM32F1xx_DFP.2.4.0</PackID>
          <OutputDirectory>.\\Objects\\</OutputDirectory>
          <ListingPath>.\\Listings\\</ListingPath>
          <OutputName>tempcontroller</OutputName>
          <CreateExecutable>1</CreateExecutable>
          <CreateHEXFile>1</CreateHEXFile>
        </TargetCommonOption>
      </TargetOption>
      <Groups>
        <Group>
          <GroupName>Application</GroupName>
          <Files>
            <File>
              <FileName>main.c</FileName>
              <FileType>1</FileType>
              <FilePath>..\\Core\\Src\\main.c</FilePath>
            </File>
            <File>
              <FileName>stm32f1xx_hal_msp.c</FileName>
              <FileType>1</FileType>
              <FilePath>..\\Core\\Src\\stm32f1xx_hal_msp.c</FilePath>
            </File>
          </Files>
        </Group>
      </Groups>
    </Target>
  </Targets>
</Project>
